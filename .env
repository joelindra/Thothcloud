# App Config
PROJECT_NAME=ThothCloud
SECRET_KEY=thoth_super_secret_key_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
POSTGRES_USER=thothadmin
POSTGRES_PASSWORD=thothpassword
POSTGRES_DB=thothcloud
DB_HOST=db
DB_PORT=5432

# Storage
STORAGE_PATH=../storage
CHUNK_SIZE=5242880 # 5MB per chunk default

# Security Enhancements
ENVIRONMENT=development
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_UPLOAD=20/minute
ENABLE_SECURITY_HEADERS=true
FILE_EXTENSION_BLACKLIST=.exe,.bat,.sh,.php,.phtml,.vbs,.js
